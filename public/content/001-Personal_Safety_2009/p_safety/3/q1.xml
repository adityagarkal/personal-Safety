    <texts>
      <txt a="X" c="X" e="-3" pt="1">Which are the most common injuries in general on board?</txt>
      <txt crct="100" c="X">Toxic injuries</txt>
      <txt crct="88" c="X">Sprain, cuts or twisting of arms, hands or fingers</txt>
      <txt crct="52" c="X">Head injuries from falling objects</txt>
      <txt crct="86" c="X">Foreign bodies in eyes from welding, dust etc.</txt>
      <txt crct="40" c="X">Damage to ears caused by loud noises</txt>
      <txt crct="41" c="X">Burns from steam, hot oil or chemicals</txt>
      <txt crct="50" c="X">Injuries of back or shoulders caused by poor working posture or wrong lifting techniques.</txt>
      <txt crct="26" c="X">Sprain or cuts in legs, feet or toes.</txt>
    </texts>
