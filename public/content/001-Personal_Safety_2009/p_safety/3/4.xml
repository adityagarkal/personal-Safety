      <txt c="X" s="2" y="200" x="100">Risk of explosion/fire</txt>
      <txt c="X" s="2" y="250" x="100">Loss of engine and steering power</txt>
      <txt c="X" s="2" y="300" x="100">Rough weather navigation</txt>
    </texts>
