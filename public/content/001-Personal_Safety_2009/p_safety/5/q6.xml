    <texts>
      <txt a="X" c="X" e="-3" pt="1">Which are the most common injuries in general on board?</txt>
      <txt crct="32" c="X">Toxic injuries</txt>
      <txt crct="74" c="X">Sprain, cuts or twisting of arms, hands or fingers</txt>
      <txt crct="88" c="X">Head injuries from falling objects</txt>
      <txt crct="54" c="X">Foreign body in eyes from welding, dust etc.</txt>
      <txt crct="60" c="X">Damage to ears caused by loud noises</txt>
      <txt crct="41" c="X">Burns from steam, hot oil or chemicals</txt>
      <txt crct="68" c="X">Injuries of back or shoulders caused by poor working posture or wrong lifting techniques.</txt>
      <txt crct="58" c="X">Sprain or cuts in legs, feet or toes.</txt>
    </texts>
